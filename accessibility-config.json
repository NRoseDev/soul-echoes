{
  "accessibility_framework": {
    "version": "1.0.0",
    "features": {
      "dyslexia_support": {
        "enabled": true,
        "supported_fonts": ["OpenDyslexic", "Verdana", "Comic Sans"],
        "default_line_spacing": "1.5em",
        "default_letter_spacing": "0.12em",
        "calm_tones_overlay": {
          "enabled": true,
          "themes": ["warm_cream", "soft_sage", "pastel_violet", "dark_charcoal"]
        }
      },
      "asl_and_gesture_engine": {
        "enabled": true,
        "input_modes": ["point", "type", "talk", "sign_language_gesture"],
        "video_stream_tracking": {
          "enabled": true,
          "real_time_translation": true
        }
      },
      "external_device_hardware": {
        "enabled": true,
        "protocols": ["USB_HID", "Bluetooth_LE", "WebMIDI"],
        "device_types": ["adaptive_switches", "foot_pedals", "eye_tracking_arrays", "custom_macro_boards"]
      }
    }
  }
}
